  "author": "Peter Cha (https://github.com/PeterCha90)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterCha90/oasis.git"
  },
  "homepage": "https://github.com/PeterCha90/oasis#readme",
