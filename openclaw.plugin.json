{
  "id": "oasis",
  "name": "OASIS — Prompt Injection Defense",
  "description": "Read tools run freely, execute tools require Slack approval with risk scoring",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "readTools": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["read", "glob", "grep", "web_search", "ollama_web_search"],
        "description": "Tools that run freely without approval"
      },
      "executeTools": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["exec", "bash", "write", "edit", "apply_patch", "web_fetch", "ollama_web_fetch", "file_delete"],
        "description": "Tools that require approval before execution"
      },
      "blockedPatterns": {
        "type": "array",
        "items": { "type": "string" },
        "default": [
          "rm\\s+(-rf|--recursive)\\s+[/~]",
          "mkfs\\b",
          "dd\\s+if=",
          ":(){\\s*:|\\s*:&\\s*};",
          "chmod\\s+777\\s+[/~]",
          "curl.*\\|\\s*(bash|sh|zsh)",
          "wget.*\\|\\s*(bash|sh|zsh)"
        ],
        "description": "Regex patterns that cause immediate block (never allowed)"
      },
      "suspiciousDomains": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["*.tk", "*.ml", "*.ga", "*.cf", "*.gq", "*.xyz", "*.top", "*.buzz"],
        "description": "Domain patterns that increase risk score"
      },
      "riskThreshold": {
        "type": "number",
        "default": 0.7,
        "description": "Risk score threshold — above this shows critical severity"
      },
      "timeoutMs": {
        "type": "number",
        "default": 120000,
        "description": "Approval timeout in milliseconds"
      },
      "timeoutBehavior": {
        "type": "string",
        "enum": ["allow", "deny"],
        "default": "deny",
        "description": "What happens when approval times out"
      },
      "llmValidation": {
        "type": "boolean",
        "default": false,
        "description": "Enable secondary LLM validation (experimental)"
      }
    }
  }
}
